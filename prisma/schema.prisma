generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum ItemStatus {
  IN_STOCK
  LISTED
  SOLD
  CONSIGNED
}

enum ItemCondition {
  DEADSTOCK
  NEW_WITH_BOX
  USED
}

enum Currency {
  USD
  CAD
  GBP
  EUR
  AUD
  JPY
}

enum Marketplace {
  STOCKX
  GOAT
  EBAY
  FLIGHTCLUB
  STADIUMGOODS
  OTHER
}

enum ExpenseType {
  SHIPPING
  BOT_FEE
  MARKETPLACE_FEE
  ADVERTISING
  STORAGE
  SUPPLIES
  CUSTOM
}

enum AlertDirection {
  ABOVE
  BELOW
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum Theme {
  LIGHT
  DARK
  UNICORN
}

// ─── CORE MODELS ──────────────────────────────────────────────────────────────

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  name              String?
  avatarUrl         String?
  plan              Plan           @default(FREE)
  stripeCustomerId  String?        @unique
  stripeSubId       String?        @unique
  currency          Currency       @default(USD)
  theme             Theme          @default(LIGHT)
  phone             String?
  pushEndpoint      String?        // Web push subscription JSON
  teamId            String?
  role              String         @default("owner") // owner | member (team)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  inventory         InventoryItem[]
  sales             Sale[]
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  priceAlerts       PriceAlert[]
  team              Team?           @relation(fields: [teamId], references: [id])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   @unique
  createdAt DateTime @default(now())
  members   User[]
}

model InventoryItem {
  id            String        @id @default(uuid())
  userId        String
  sku           String        // e.g. "DD1391-100"
  name          String        // e.g. "Air Jordan 1 Retro High OG Chicago"
  brand         String
  size          String        // e.g. "10.5" or "L" (apparel)
  colorway      String?
  purchasePrice Decimal       @db.Decimal(10, 2)
  purchaseDate  DateTime
  condition     ItemCondition @default(DEADSTOCK)
  status        ItemStatus    @default(IN_STOCK)
  marketplace   Marketplace?  // where listed
  askingPrice   Decimal?      @db.Decimal(10, 2)
  notes         String?
  imageUrl      String?
  currency      Currency      @default(USD)
  tags          String[]      // flexible tags
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale   Sale?
  expenses Expense[]
  priceHistory MarketPrice[]

  @@index([userId, sku])
  @@index([userId, status])
  @@unique([sku, size])
}

model MarketPrice {
  id          String      @id @default(uuid())
  sku         String
  size        String
  marketplace Marketplace
  askPrice    Decimal?    @db.Decimal(10, 2)
  lastSold    Decimal?    @db.Decimal(10, 2)
  bidPrice    Decimal?    @db.Decimal(10, 2)
  fetchedAt   DateTime    @default(now())

  inventoryItem InventoryItem? @relation(fields: [sku, size], references: [sku, size])

  @@index([sku, size, marketplace])
  @@index([fetchedAt])
}

model Sale {
  id              String      @id @default(uuid())
  userId          String
  inventoryItemId String      @unique
  salePrice       Decimal     @db.Decimal(10, 2)
  saleDate        DateTime
  marketplace     Marketplace
  currency        Currency    @default(USD)
  buyerHandle     String?
  trackingNumber  String?
  notes           String?
  createdAt       DateTime    @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  expenses      Expense[]

  @@index([userId, saleDate])
}

model Expense {
  id              String      @id @default(uuid())
  userId          String
  saleId          String?
  inventoryItemId String?
  type            ExpenseType
  description     String?
  amount          Decimal     @db.Decimal(10, 2)
  currency        Currency    @default(USD)
  date            DateTime
  createdAt       DateTime    @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale          Sale?          @relation(fields: [saleId], references: [id])
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([userId, date])
}

model RecurringExpense {
  id          String      @id @default(uuid())
  userId      String
  type        ExpenseType
  description String
  amount      Decimal     @db.Decimal(10, 2)
  currency    Currency    @default(USD)
  dayOfMonth  Int         // 1–28
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceAlert {
  id                  String               @id @default(uuid())
  userId              String
  sku                 String
  size                String
  productName         String
  marketplace         Marketplace
  targetPrice         Decimal              @db.Decimal(10, 2)
  direction           AlertDirection
  notificationChannel NotificationChannel
  isActive            Boolean              @default(true)
  triggeredAt         DateTime?
  createdAt           DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([sku, size, marketplace])
}
