generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum ItemStatus {
  IN_STOCK
  LISTED
  SOLD
  CONSIGNED
}

enum ItemCondition {
  NEW
  LIKE_NEW
  USED_EXCELLENT
  USED_GOOD
  USED_FAIR
  REFURBISHED
  DAMAGED
  DEADSTOCK // legacy alias for NEW
  NEW_WITH_BOX // legacy alias for NEW
  USED // legacy alias for USED_GOOD
}

enum Currency {
  USD
  CAD
  GBP
  EUR
  AUD
  JPY
}

enum Marketplace {
  STOCKX
  GOAT
  EBAY
  FLIGHTCLUB
  STADIUMGOODS
  AMAZON
  MERCARI
  POSHMARK
  FACEBOOK
  SHOPIFY
  GRAILED
  DEPOP
  OFFERUP
  IN_PERSON
  OTHER
}

enum ExpenseType {
  SHIPPING
  BOT_FEE // legacy – kept for backward compat
  SUBSCRIPTION_FEE
  MARKETPLACE_FEE
  ADVERTISING
  STORAGE
  SUPPLIES
  PACKAGING
  RETURNS
  CUSTOM
}

enum AlertDirection {
  ABOVE
  BELOW
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum Theme {
  LIGHT
  DARK
  UNICORN
}

// ─── CORE MODELS ──────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  name                String?
  avatarUrl           String?
  plan                Plan     @default(FREE)
  stripeCustomerId    String?  @unique
  stripeSubId         String?  @unique
  currency            Currency @default(USD)
  theme               Theme    @default(LIGHT)
  phone               String?
  pushEndpoint        String? // Web push subscription JSON
  emailNotifications  Boolean  @default(true)
  smsNotifications    Boolean  @default(false)
  pushNotifications   Boolean  @default(false)
  weeklySummary       Boolean  @default(true)
  priceAlertTriggered Boolean  @default(true)
  teamId              String?
  role                String   @default("owner") // owner | member (team)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  inventory         InventoryItem[]
  sales             Sale[]
  expenses          Expense[]
  recurringExpenses RecurringExpense[]
  priceAlerts       PriceAlert[]
  integrations      Integration[]
  team              Team?              @relation(fields: [teamId], references: [id])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   @unique
  createdAt DateTime @default(now())
  members   User[]
  invites   Invite[]
  integrations Integration[]
}

model Invite {
  id        String   @id @default(uuid())
  teamId    String
  email     String
  role      String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([token])
}

model InventoryItem {
  id            String        @id @default(uuid())
  userId        String
  sku           String // product identifier (e.g. model number, UPC, or custom ID)
  name          String // product name
  brand         String
  size          String? // variant: shoe size, clothing size, storage capacity, etc.
  color         String? // color, colorway, or finish
  category      String? // e.g. "Sneakers", "Electronics", "Trading Cards"
  purchasePrice Decimal       @db.Decimal(10, 2)
  purchaseDate  DateTime
  condition     ItemCondition @default(NEW)
  status        ItemStatus    @default(IN_STOCK)
  marketplace   Marketplace? // where listed
  askingPrice   Decimal?      @db.Decimal(10, 2)
  notes         String?
  imageUrl      String?
  currency      Currency      @default(USD)
  tags          String[] // flexible tags
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale         Sale?
  expenses     Expense[]
  priceHistory MarketPrice[]

  @@unique([userId, sku, size])
  @@index([userId, sku])
  @@index([userId, status])
}

model MarketPrice {
  id              String      @id @default(uuid())
  sku             String
  size            String?
  marketplace     Marketplace
  askPrice        Decimal?    @db.Decimal(10, 2)
  lastSold        Decimal?    @db.Decimal(10, 2)
  bidPrice        Decimal?    @db.Decimal(10, 2)
  fetchedAt       DateTime    @default(now())
  inventoryItemId String?

  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([sku, size, marketplace])
  @@index([fetchedAt])
}

model Sale {
  id              String      @id @default(uuid())
  userId          String
  inventoryItemId String      @unique
  salePrice       Decimal     @db.Decimal(10, 2)
  platformFee     Decimal     @default(0) @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  saleDate        DateTime
  marketplace     Marketplace
  currency        Currency    @default(USD)
  buyerHandle     String?
  trackingNumber  String?
  notes           String?
  createdAt       DateTime    @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  expenses      Expense[]

  @@index([userId, saleDate])
}

model Expense {
  id              String      @id @default(uuid())
  userId          String
  saleId          String?
  inventoryItemId String?
  type            ExpenseType
  description     String?
  amount          Decimal     @db.Decimal(10, 2)
  currency        Currency    @default(USD)
  date            DateTime
  createdAt       DateTime    @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sale          Sale?          @relation(fields: [saleId], references: [id])
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  @@index([userId, date])
}

model RecurringExpense {
  id          String      @id @default(uuid())
  userId      String
  type        ExpenseType
  description String
  amount      Decimal     @db.Decimal(10, 2)
  currency    Currency    @default(USD)
  dayOfMonth  Int // 1–28
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceAlert {
  id                  String              @id @default(uuid())
  userId              String
  sku                 String
  size                String?
  productName         String
  marketplace         Marketplace
  targetPrice         Decimal             @db.Decimal(10, 2)
  direction           AlertDirection
  notificationChannel NotificationChannel
  isActive            Boolean             @default(true)
  triggeredAt         DateTime?
  createdAt           DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([sku, size, marketplace])
}

model Integration {
  id           String    @id @default(uuid())
  userId       String
  teamId       String?
  platform     String    // e.g., "SHOPIFY", "EBAY"
  accessToken  String    // Encrypted access token or API key
  refreshToken String?   // Encrypted refresh token (optional)
  expiresAt    DateTime? // Expiration date/time (optional)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@index([teamId])
}
